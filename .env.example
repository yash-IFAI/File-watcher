# Required auth for Planx API
AUTOMATED_INGEST_USERNAME=watcher-service-user
AUTOMATED_INGEST_PASSWORD=replace-me

# Planx API connection
AUTOMATED_INGEST_API_BASE_URL=http://localhost:5000
AUTOMATED_INGEST_LOGIN_ENDPOINT=/api/auth/login
AUTOMATED_INGEST_PROCESS_ENDPOINT=/api/extractai/process-automated-brief

# Watcher file-system locations
AUTOMATED_INGEST_WATCH_ROOT=./uploads/automated-briefs
AUTOMATED_INGEST_PROCESSED_ROOT=./uploads/automated-briefs/.processed

# Comma-separated folder names to watch
AUTOMATED_INGEST_WATCH_FOLDERS=us bank,newell

# Comma-separated allowed file extensions
AUTOMATED_INGEST_ALLOWED_EXTENSIONS=.pdf,.doc,.docx

# Optional JSON map for folder-specific config IDs
# Example: {"us bank": 3, "newell": 5}
AUTOMATED_INGEST_FOLDER_CONFIG_MAP=
